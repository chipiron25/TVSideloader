<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        android:gravity="center_vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Volver"
            android:backgroundTint="@color/bg_secondary"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:focusable="true"
            android:layout_marginEnd="20dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Instalador de APKs"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Tabs -->
        <Button
            android:id="@+id/tab_browse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explorar almacenamiento"
            android:backgroundTint="@color/accent"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:focusable="true"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/tab_download"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Descargar desde URL"
            android:backgroundTint="@color/bg_secondary"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:focusable="true"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actualizar"
            android:backgroundTint="@color/bg_secondary"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:focusable="true" />
    </LinearLayout>

    <!-- Panel: Explorar -->
    <LinearLayout
        android:id="@+id/panel_browse"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_browse_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:padding="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"
            android:focusable="true"
            android:descendantFocusability="afterDescendants" />
    </LinearLayout>

    <!-- Panel: Descargar -->
    <LinearLayout
        android:id="@+id/panel_download"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:padding="60dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="URL directa del archivo APK:"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="https://ejemplo.com/app.apk"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:hintTextColor="@color/text_secondary"
            android:background="@color/bg_card"
            android:padding="16dp"
            android:inputType="textUri"
            android:singleLine="true"
            android:focusable="true"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del archivo (opcional):"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_filename"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="mi_aplicacion  (se añade .apk automáticamente)"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:hintTextColor="@color/text_secondary"
            android:background="@color/bg_card"
            android:padding="16dp"
            android:singleLine="true"
            android:focusable="true"
            android:layout_marginBottom="28dp" />

        <Button
            android:id="@+id/btn_download"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Descargar e instalar"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/accent"
            android:focusable="true"
            android:layout_marginBottom="20dp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:max="100"
            android:visibility="gone"
            android:progressTint="@color/accent"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_light"
            android:textSize="16sp"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_dl_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>
